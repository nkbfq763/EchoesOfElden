[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://title.gd" id="1"]

[node name="Title" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.08, 0.12, 0.24, 1)

[node name="Panel" type="VBoxContainer" parent="."]
layout_mode = 0
offset_left = 200.0
offset_top = 70.0
offset_right = 440.0
offset_bottom = 300.0
theme_override_constants/separation = 18

[node name="TitleLabel" type="Label" parent="Panel"]
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "ETARNA"
horizontal_alignment = 1

[node name="Subtitle" type="Label" parent="Panel"]
layout_mode = 2
text = "A Tale Begins"
horizontal_alignment = 1

[node name="NewButton" type="Button" parent="Panel"]
layout_mode = 2
text = "New Game"

[node name="ContinueButton" type="Button" parent="Panel"]
layout_mode = 2
text = "Continue"

[connection signal="pressed" from="Panel/NewButton" to="." method="_on_new_button_pressed"]
[connection signal="pressed" from="Panel/ContinueButton" to="." method="_on_continue_button_pressed"]

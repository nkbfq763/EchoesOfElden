; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="town"
run/main_scene="res://title.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameData="*res://game_data.gd"

[display]

window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"
display/window/size/viewport_width=640
display/window/size/viewport_height=360
display/window/size/window_width_override=1280
display/window/size/window_height_override=720

[editor_plugins]

enabled=PackedStringArray("res://addons/zylann.hterrain/plugin.cfg")

